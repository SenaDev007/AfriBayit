# ─── AfriBayit — Environment Variables Template ──────────────────────────
# Copy this file to .env and fill in your values

# PostgreSQL Database (Neon)
DATABASE_URL=postgresql://neondb_owner:npg_VPlSR7Z9UiYD@ep-polished-glitter-agic460a-pooler.c-2.eu-central-1.aws.neon.tech/AfriBayit?sslmode=require&channel_binding=require

# NextAuth — Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ─── Encryption ──────────────────────────────────────────────────────────
# AES-256-GCM encryption key (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Cloudflare R2 Storage ──────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=afribayit
R2_PUBLIC_URL=https://cdn.afribayit.com

# ─── Sentry Error Tracking ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Mapbox (Interactive Maps) ──────────────────────────────────────────
# Get your token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ─── Notification Channels ──────────────────────────────────────────────

# Resend (Email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Africa's Talking (SMS notifications)
AFRICASTALKING_API_KEY=atsk_xxxxxxxxxxxxx
AFRICASTALKING_USERNAME=sandbox

# Web Push (Push notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Upstash Redis (Caching, Sessions, Rate Limiting) ─────────────────────
# Get your credentials at https://console.upstash.com/
# Optional — system falls back to in-memory cache if not configured
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron Secret (Payout Engine Scheduler) ────────────────────────────────
# Used to protect the /api/cron/payouts endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Pusher (Real-time Events & Notifications) ──────────────────────────
# Get your credentials at https://dashboard.pusher.com/
# Optional — system falls back to DB-only polling if not configured
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ─── FedaPay (Mobile Money & Card Payments for WAEMU) ──────────────────────
# Get your keys at https://app.fedapay.com/dashboard/api-keys
# Primary secret key (also accepted as FEDAPAY_API_KEY for backward compatibility)
FEDAPAY_SECRET_KEY=
# Public key for webhook signature verification
FEDAPAY_PUBLIC_KEY=
# Environment: sandbox (test) or live (production)
# Defaults to 'sandbox' in development, 'live' in production
FEDAPAY_ENVIRONMENT=sandbox

# ─── Stripe (International Card & Bank Transfer Payments) ────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
