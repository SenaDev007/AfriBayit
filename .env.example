# ─── AfriBayit — Environment Variables Template ──────────────────────────
# Copy this file to .env and fill in your values

# ─── Backend API URL (CDC §3.1.2 — NestJS on Fly.io) ─────────────────────
# Development: http://localhost:3001
# Production: https://afribayit-api.fly.dev
NEXT_PUBLIC_API_URL=http://localhost:3001

# PostgreSQL Database (Neon) — shared with backend
# SECURITY (P1.4 — juillet 2026) : Le password n'est plus hardcodé dans ce template.
# Récupérez le DATABASE_URL complet depuis le dashboard Neon ou votre vault.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# NextAuth — Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ─── Encryption ──────────────────────────────────────────────────────────
# AES-256-GCM encryption key (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Cloudflare R2 Storage ──────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=afribayit
R2_PUBLIC_URL=https://cdn.afribayit.com

# ─── Sentry Error Tracking ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Notification Channels ──────────────────────────────────────────────

# Resend (Email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Africa's Talking (SMS notifications)
AFRICASTALKING_API_KEY=atsk_xxxxxxxxxxxxx
AFRICASTALKING_USERNAME=sandbox

# Web Push (Push notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Upstash Redis (Caching, Rate Limiting, Sessions) ────────────────────
# Optional: If not configured, the app falls back to in-memory storage.
# Get credentials from: https://console.upstash.com/
# Used for: distributed rate limiting, API response caching, session storage
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── z.ai API Key ────────────────────────────────────────────────────────
ZAI_API_KEY=

# ─── Mapbox ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Payments ────────────────────────────────────────────────────────────
FEDAPAY_PUBLIC_KEY=
FEDAPAY_SECRET_KEY=
FEDAPAY_SANDBOX=true

# ─── Backend API Configuration ───────────────────────────────────────────
# The frontend calls the NestJS backend (afribayit-api) for all API requests.
# Backend repo: https://github.com/SenaDev007/afribayit-api
# Backend deploys on Fly.io (Johannesburg + Paris) per CDC §3.1.3.
#
# The API client (src/lib/api-client.ts) uses this URL for all requests.
# Old Next.js API routes (src/app/api/*) are deprecated and will be removed.
