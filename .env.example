# ─── AfriBayit Frontend — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values

# ─── Backend API URL (NestJS on Railway) ─────────────────────────────────
# Development: http://localhost:3001
# Production: https://afribayit-api-xxxx.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── App URL ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── NextAuth (shared secret with backend) ───────────────────────────────
# Must match NEXTAUTH_SECRET on the backend (Railway)
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth Providers ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── Mapbox (frontend maps) ──────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Sentry (frontend error tracking) ────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Pusher (frontend realtime — client keys only) ───────────────────────
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# Note: Backend secrets (DATABASE_URL, STRIPE, FEDAPAY, R2, REDIS, SMS, etc.)
# are configured on Railway, NOT on the frontend.
