// AfriBayit - Prisma Schema v1.0
// Plateforme Immobilière Pan-Africaine

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserType {
  BUYER
  SELLER
  INVESTOR
  TOURIST
  ARTISAN
  AGENCY
  GUESTHOUSE_OWNER
  NOTAIRE
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum KYCStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  STUDIO
  OFFICE
  LAND
  COMMERCIAL
  WAREHOUSE
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  RENTED
  SOLD
  ARCHIVED
}

enum ListingType {
  SALE
  LONG_TERM_RENTAL
  SHORT_TERM_RENTAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  DISPUTED
}

enum TransactionStatus {
  PENDING
  ESCROW
  RELEASED
  REFUNDED
  DISPUTED
}

enum ArtisanCategory {
  GROS_OEUVRE
  SECOND_OEUVRE
  FINITION_DECORATION
  GENIE_TECHNIQUE
  EXTERIEURS
  RENOVATION_MAINTENANCE
  NUMERIQUE_INNOVATION
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
}

enum Country {
  BJ // Bénin
  CI // Côte d'Ivoire
  BF // Burkina Faso
  TG // Togo
  SN // Sénégal
  GH // Ghana
  NG // Nigeria
  CM // Cameroun
  ML // Mali
  NE // Niger
  OTHER
}

enum Currency {
  XOF // FCFA UEMOA
  XAF // FCFA CEMAC
  GHS // Cedi ghanéen
  NGN // Naira
  KES // Shilling kényan
  ZAR // Rand sud-africain
  EUR
  USD
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  phone         String?    @unique
  emailVerified DateTime?
  phoneVerified DateTime?
  name          String?
  firstName     String?
  lastName      String?
  image         String?
  password      String?    // hashed

  userType      UserType   @default(BUYER)
  status        UserStatus @default(PENDING)
  kycStatus     KYCStatus  @default(NONE)
  kycLevel      KYCLevel   @default(KYC0)
  kycMonthlySpent Int      @default(0)   // XOF spent this calendar month
  kycMonthReset DateTime?               // date of last monthly reset

  country       Country?
  city          String?
  address       String?

  bio           String?
  language      String     @default("fr")

  // Reputation
  reputationScore Int      @default(500)
  totalReviews    Int      @default(0)

  // Premium
  isPremium     Boolean    @default(false)
  premiumUntil  DateTime?

  // Loyalty
  loyaltyPoints Int        @default(0)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt   DateTime?

  // Relations
  accounts      Account[]
  sessions      Session[]
  properties    Property[]
  bookings      Booking[]  @relation("BookingGuest")
  hostBookings  Booking[]  @relation("BookingHost")
  guesthouses   Guesthouse[]
  artisanProfile  Artisan?
  notaireProfile  NotaireProfile?
  enrollments     Enrollment[]
  sentMessages  Message[]  @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  reviews       Review[]   @relation("ReviewAuthor")
  receivedReviews Review[] @relation("ReviewTarget")
  favorites     Favorite[]
  notifications Notification[]
  transactions  Transaction[]
  kycDocuments  KYCDocument[]
  escrowAsBuyer  EscrowTransaction[] @relation("EscrowBuyer")
  escrowAsSeller EscrowTransaction[] @relation("EscrowSeller")
  forumPosts     ForumPost[]  @relation("ForumPostAuthor")
  forumReplies   ForumReply[] @relation("ForumReplyAuthor")
  forumLikes     ForumLike[]  @relation("ForumLikes")
  missions       ArtisanMission[] @relation("MissionClient")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// PROPERTIES (Immobilier Core)
// ─────────────────────────────────────────────

model Property {
  id          String         @id @default(cuid())
  title       String
  description String
  slug        String         @unique

  type        PropertyType
  listingType ListingType
  status      PropertyStatus @default(DRAFT)

  // Pricing
  price       Float
  priceUnit   String         @default("FCFA") // FCFA, XOF, EUR...
  currency    Currency       @default(XOF)

  // Location
  country     Country
  city        String
  district    String?
  address     String?
  latitude    Float?
  longitude   Float?

  // Features
  surface     Float?         // m²
  bedrooms    Int?
  bathrooms   Int?
  floors      Int?
  yearBuilt   Int?

  // Boolean features
  hasGarage   Boolean        @default(false)
  hasPool     Boolean        @default(false)
  hasGarden   Boolean        @default(false)
  hasBalcony  Boolean        @default(false)
  hasSecurity Boolean        @default(false)
  hasGenerator Boolean       @default(false)
  hasWifi     Boolean        @default(false)
  hasAC       Boolean        @default(false)

  // Extra features (JSONB)
  features    Json?

  // Analytics
  viewCount   Int            @default(0)
  favoriteCount Int          @default(0)

  // Score d'investissement 0-100
  investmentScore Float?

  // Virtual tour
  virtualTourUrl String?
  matterportId   String?

  // Legal document (§10B CDC) — validated at publication
  legalDocType   String?        // Code du document foncier (ex: TITRE_FONCIER, PUH...)
  legalDocUrl    String?        // URL du document uploadé (Cloudflare R2 / local)
  legalDocStatus String         @default("PENDING") // PENDING | ACCEPTED | CONDITIONAL | REJECTED

  // Semantic search — pgvector (text-embedding-3-small, 1536 dims)
  embedding      Unsupported("vector(1536)")?

  ownerId     String
  owner       User           @relation(fields: [ownerId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  publishedAt DateTime?

  // Relations
  images      PropertyImage[]
  bookings    Booking[]
  reviews     Review[]
  favorites   Favorite[]
  priceHistory PriceHistory[]

  @@index([country, city])
  @@index([type, listingType])
  @@index([price])
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  url         String
  alt         String?
  order       Int      @default(0)
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model PriceHistory {
  id         String   @id @default(cuid())
  propertyId String
  price      Float
  currency   Currency
  date       DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("price_history")
}

// ─────────────────────────────────────────────
// GUESTHOUSES
// ─────────────────────────────────────────────

model Guesthouse {
  id          String   @id @default(cuid())
  name        String
  description String
  slug        String   @unique

  // Location
  country     Country
  city        String
  district    String?
  address     String?
  latitude    Float?
  longitude   Float?

  // Features
  hasBreakfast Boolean @default(false)
  hasParking   Boolean @default(false)
  hasWifi      Boolean @default(true)
  hasAC        Boolean @default(false)
  hasPool      Boolean @default(false)

  // Certification
  isCertified  Boolean  @default(false)
  certifiedAt  DateTime?
  certScore    Float?

  // Rating
  avgRating    Float    @default(0)
  totalReviews Int      @default(0)

  // Status
  isActive     Boolean  @default(true)

  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  rooms       GuesthouseRoom[]
  images      GuesthouseImage[]
  staff       GuesthouseStaff[]
  pricingRules GuesthousePricingRule[]
  bookings    GuesthouseBooking[]
  reviews     Review[]

  @@map("guesthouses")
}

model GuesthouseRoom {
  id           String   @id @default(cuid())
  guesthouseId String
  name         String
  description  String?

  capacity     Int      @default(2)
  bedType      String?  // King, Queen, Twin...

  // Pricing
  basePrice    Float
  currency     Currency @default(XOF)

  // Features (JSONB)
  amenities    Json?

  // Status
  isAvailable  Boolean  @default(true)

  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  images       GuesthouseRoomImage[]
  bookings     GuesthouseBooking[]

  @@map("guesthouse_rooms")
}

model GuesthouseRoomImage {
  id     String @id @default(cuid())
  roomId String
  url    String
  alt    String?
  order  Int    @default(0)

  room   GuesthouseRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("guesthouse_room_images")
}

model GuesthouseImage {
  id           String     @id @default(cuid())
  guesthouseId String
  url          String
  alt          String?
  order        Int        @default(0)
  isPrimary    Boolean    @default(false)

  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  @@map("guesthouse_images")
}

model GuesthouseStaff {
  id           String     @id @default(cuid())
  guesthouseId String
  name         String
  role         String     // receptionist, cleaner, manager
  phone        String?
  accessLevel  String     @default("limited")

  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@map("guesthouse_staff")
}

model GuesthousePricingRule {
  id           String     @id @default(cuid())
  guesthouseId String
  name         String
  startDate    DateTime
  endDate      DateTime
  multiplier   Float      // ex: 1.5 for +50%
  description  String?    // "Fête nationale", "CAN 2026"

  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  @@map("guesthouse_pricing_rules")
}

model GuesthouseBooking {
  id           String        @id @default(cuid())
  guesthouseId String
  roomId       String
  guestId      String

  checkIn      DateTime
  checkOut     DateTime
  nights       Int
  guests       Int

  // Pricing
  baseAmount   Float
  finalAmount  Float
  currency     Currency      @default(XOF)

  // Options
  includeBreakfast Boolean   @default(false)
  breakfastAmount Float?

  status       BookingStatus @default(PENDING)

  // Payment
  paidAt       DateTime?
  paymentRef   String?

  guesthouse   Guesthouse    @relation(fields: [guesthouseId], references: [id])
  room         GuesthouseRoom @relation(fields: [roomId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("guesthouse_bookings")
}

// ─────────────────────────────────────────────
// BOOKINGS (Short-term Rentals / Properties)
// ─────────────────────────────────────────────

model Booking {
  id         String        @id @default(cuid())
  propertyId String
  guestId    String
  hostId     String

  checkIn    DateTime
  checkOut   DateTime
  nights     Int
  guests     Int

  // Pricing
  nightlyRate  Float
  totalAmount  Float
  serviceFee   Float        // commission voyageur 12-15%
  hostAmount   Float        // montant net hôte
  currency     Currency     @default(XOF)

  status       BookingStatus @default(PENDING)

  // Payment
  paidAt       DateTime?
  paymentRef   String?
  paymentMethod String?     // mobile_money, card, etc.

  // Messages
  guestNote    String?
  hostNote     String?

  // Check-in/out
  checkInCode  String?      // QR code
  checkedInAt  DateTime?
  checkedOutAt DateTime?

  property    Property  @relation(fields: [propertyId], references: [id])
  guest       User      @relation("BookingGuest", fields: [guestId], references: [id])
  host        User      @relation("BookingHost", fields: [hostId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transaction Transaction?

  @@map("bookings")
}

// ─────────────────────────────────────────────
// ARTISANS — ProMatch
// ─────────────────────────────────────────────

model Artisan {
  id          String          @id @default(cuid())
  userId      String          @unique

  businessName String?
  category    ArtisanCategory
  specialty   String[]
  description String?

  // Location
  country     Country
  city        String
  serviceArea String[]        // autres villes couvertes

  // Experience
  yearsExp    Int             @default(0)

  // Certification
  isCertified  Boolean        @default(false)
  certifiedAt  DateTime?
  certScore    Float?

  // Rating
  avgRating    Float          @default(0)
  totalReviews Int            @default(0)

  // Pricing
  hourlyRate   Float?
  dailyRate    Float?
  currency     Currency       @default(XOF)

  // Availability
  isAvailable  Boolean        @default(true)
  emergencyService Boolean    @default(false) // disponible 24/7

  // Portfolio
  completedJobs Int           @default(0)

  user        User            @relation(fields: [userId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  images      ArtisanImage[]
  services    ArtisanService[]
  reviews     Review[]
  quotes      ArtisanQuote[]

  @@map("artisans")
}

model ArtisanImage {
  id        String   @id @default(cuid())
  artisanId String
  url       String
  caption   String?
  order     Int      @default(0)

  artisan   Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("artisan_images")
}

model ArtisanService {
  id          String   @id @default(cuid())
  artisanId   String
  name        String
  description String?
  basePrice   Float?
  currency    Currency @default(XOF)
  duration    String?  // "2 jours", "1 semaine"

  artisan     Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("artisan_services")
}

// ─────────────────────────────────────────────
// COURSES & FORMATION — AfriBayit Academy
// ─────────────────────────────────────────────

model Course {
  id          String      @id @default(cuid())
  title       String
  description String
  slug        String      @unique

  level       CourseLevel @default(BEGINNER)
  category    String      // immobilier, investissement, legal, artisan...
  language    String      @default("fr")

  price       Float       @default(0)
  currency    Currency    @default(XOF)

  thumbnailUrl String?
  videoUrl     String?
  duration     Int?        // minutes

  isPublished  Boolean    @default(false)
  isCertified  Boolean    @default(false)

  instructorId String?    // userId

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  enrollments Enrollment[]
  modules     CourseModule[]

  @@map("courses")
}

model CourseModule {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int
  videoUrl String?
  duration Int?   // minutes

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_modules")
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String

  progress    Float     @default(0) // 0-100%
  completedAt DateTime?
  certUrl     String?   // URL certificat

  user        User      @relation(fields: [userId], references: [id])
  course      Course    @relation(fields: [courseId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ─────────────────────────────────────────────
// TRANSACTIONS & ESCROW
// ─────────────────────────────────────────────

model Transaction {
  id          String            @id @default(cuid())
  bookingId   String?           @unique

  senderId    String
  receiverId  String

  amount      Float
  commission  Float             // commission AfriBayit
  netAmount   Float             // montant net reçu
  currency    Currency          @default(XOF)

  status      TransactionStatus @default(PENDING)

  type        String            // sale, short_rental, long_rental, artisan, hotel

  // Escrow
  inEscrow    Boolean           @default(false)
  escrowAt    DateTime?
  releasedAt  DateTime?

  // Payment details
  paymentMethod String?
  paymentRef    String?

  // External refs
  fedapayRef    String?         // FedaPay transaction ID

  booking     Booking?          @relation(fields: [bookingId], references: [id])
  sender      User              @relation(fields: [senderId], references: [id])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("transactions")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String    @id @default(cuid())
  authorId   String
  targetId   String?   // userId (artisan/hôte)
  propertyId String?
  guesthouseId String?
  artisanId  String?

  rating     Int       // 1-5
  title      String?
  comment    String?

  isVerified Boolean   @default(false) // vérifiée par IA

  author     User      @relation("ReviewAuthor", fields: [authorId], references: [id])
  target     User?     @relation("ReviewTarget", fields: [targetId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])
  guesthouse Guesthouse? @relation(fields: [guesthouseId], references: [id])
  artisan    Artisan?  @relation(fields: [artisanId], references: [id])

  createdAt  DateTime  @default(now())

  @@map("reviews")
}

// ─────────────────────────────────────────────
// FAVORITES
// ─────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// MESSAGES & NOTIFICATIONS
// ─────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)

  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])

  createdAt  DateTime @default(now())

  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // booking, message, review, price_alert, payment, system
  title     String
  message   String
  href      String?  // lien de navigation
  data      Json?
  isRead    Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// ONBOARDING PROFILE (§4 CDC)
// ─────────────────────────────────────────────

model OnboardingProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  profileType  String   // buyer, seller, investor, tourist, artisan, agency, guesthouse
  country      String?
  city         String?
  interests    String[] // ['achat', 'location', 'investissement'...]
  budget       String?
  notifEmail   Boolean  @default(true)
  notifSMS     Boolean  @default(false)
  notifPush    Boolean  @default(true)
  notifNews    Boolean  @default(false)
  completedAt  DateTime @default(now())

  @@map("onboarding_profiles")
}

// ─────────────────────────────────────────────
// ESCROW STATE MACHINE (§7B CDC)
// ─────────────────────────────────────────────

enum EscrowState {
  CREATED
  FUNDED
  IN_PROGRESS
  VALIDATION
  // Notarial states (§5.0bis) — PROPERTY_SALE only
  DOCS_VALIDATED      // Legal docs verified by AfriBayit admin
  GEOTRUST_VALIDATED  // GeoTrust survey completed and validated
  NOTAIRE_ASSIGNED    // Notaire accepted the dossier
  DEED_DRAFTING       // Notaire is drafting the authentic deed
  DEED_SIGNED         // Notaire signed → triggers automatic release
  FUNDS_RELEASING     // Brief state before RELEASED (payout processing)
  RELEASED
  REFUNDED
  EXPIRED
  DISPUTED
}

enum EscrowType {
  PROPERTY_SALE
  LONG_TERM_RENTAL
  SHORT_TERM_RENTAL
  ARTISAN_SERVICE
  HOTEL_BOOKING
  GEOTRUST_MISSION
}

model EscrowTransaction {
  id            String      @id @default(cuid())
  reference     String      @unique @default(cuid()) // ESC-XXXX
  type          EscrowType
  state         EscrowState @default(CREATED)

  buyerId       String
  sellerId      String

  amount        Float
  commission    Float       // 2-5% CDC §6
  netAmount     Float
  currency      Currency    @default(XOF)

  // Related entity
  propertyId    String?
  bookingId     String?
  artisanJobId  String?

  // Notarial (§5.0bis) — PROPERTY_SALE only
  notaireId     String?
  deedUrl       String?     // Cloudflare R2 URL of signed deed
  deedSignedAt  DateTime?
  deedHash      String?     // SHA-256 hash for on-chain anchoring

  // Payment
  paymentMethod String?     // mobile_money, card
  paymentRef    String?
  fedapayRef    String?

  // State timestamps
  fundedAt      DateTime?
  startedAt     DateTime?
  validationAt  DateTime?
  releasedAt    DateTime?
  refundedAt    DateTime?
  expiresAt     DateTime?

  // Validation
  buyerValidated  Boolean   @default(false)
  sellerValidated Boolean   @default(false)
  disputeReason   String?

  // Audit log
  stateHistory  Json?       // [{state, at, by}]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  buyer         User             @relation("EscrowBuyer", fields: [buyerId], references: [id])
  seller        User             @relation("EscrowSeller", fields: [sellerId], references: [id])
  notaire       NotaireProfile?  @relation("NotaireDossier", fields: [notaireId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([state])
  @@index([notaireId])
  @@map("escrow_transactions")
}

// ─────────────────────────────────────────────
// LEDGER FINANCIER DOUBLE-ENTRÉE (§7B CDC)
// ─────────────────────────────────────────────

enum LedgerEntryType {
  DEPOSIT      // Buyer funds escrow
  COMMISSION   // Platform fee deducted
  RELEASE      // Funds released to seller
  REFUND       // Funds returned to buyer
  ADJUSTMENT   // Manual admin correction
}

model LedgerEntry {
  id            String          @id @default(cuid())
  escrowId      String?         // Related escrow transaction
  entryType     LedgerEntryType
  /// Account debited (buyer:userId, seller:userId, escrow:platform, platform:revenue)
  debitAccount  String
  /// Account credited
  creditAccount String
  amount        Float
  currency      Currency        @default(XOF)
  description   String
  /// SHA256 hash of previous entry ID — immutable audit chain
  prevHash      String?
  hash          String?

  createdAt     DateTime        @default(now())

  @@index([escrowId])
  @@index([debitAccount])
  @@index([creditAccount])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────
// HOTELS & OTA (§7D CDC)
// ─────────────────────────────────────────────

enum HotelPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum HotelNetworkType {
  DIRECT   // hôtel partenaire direct
  OTA      // via OTA (Booking.com, Expedia)
}

model Hotel {
  id            String          @id @default(cuid())
  name          String
  description   String
  slug          String          @unique

  // Network type
  networkType   HotelNetworkType @default(DIRECT)
  plan          HotelPlan?

  // OTA
  bookingComId  String?         // Booking.com property ID
  otaIds        Json?           // {"booking": "xxx", "expedia": "yyy"}

  // Location
  country       Country
  city          String
  district      String?
  address       String?
  latitude      Float?
  longitude     Float?

  // Classification
  stars         Int             @default(3)
  category      String?         // hotel, resort, boutique, auberge

  // Features
  hasPool       Boolean         @default(false)
  hasRestaurant Boolean         @default(false)
  hasSpa        Boolean         @default(false)
  hasGym        Boolean         @default(false)
  hasConference Boolean         @default(false)
  hasParking    Boolean         @default(false)
  hasWifi       Boolean         @default(true)
  hasAC         Boolean         @default(true)

  // Rating
  avgRating     Float           @default(0)
  totalReviews  Int             @default(0)

  // Status
  isActive      Boolean         @default(true)
  isVerified    Boolean         @default(false)

  ownerId       String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  rooms         HotelRoom[]
  images        HotelImage[]
  bookings      HotelBooking[]

  @@index([country, city])
  @@map("hotels")
}

model HotelRoom {
  id          String        @id @default(cuid())
  hotelId     String
  name        String        // "Chambre Supérieure", "Suite Junior"
  description String?
  roomCode    String?

  capacity    Int           @default(2)
  bedType     String?       // King, Queen, Twin, Double
  floor       Int?

  // Pricing
  basePrice   Float
  currency    Currency      @default(XOF)

  // Amenities (JSONB)
  amenities   Json?

  isAvailable Boolean       @default(true)

  hotel       Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings    HotelBooking[]
  images      HotelRoomImage[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("hotel_rooms")
}

model HotelRoomImage {
  id     String    @id @default(cuid())
  roomId String
  url    String
  alt    String?
  order  Int       @default(0)

  room   HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("hotel_room_images")
}

model HotelImage {
  id        String  @id @default(cuid())
  hotelId   String
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("hotel_images")
}

model HotelBooking {
  id        String        @id @default(cuid())
  hotelId   String
  roomId    String
  guestId   String

  checkIn   DateTime
  checkOut  DateTime
  nights    Int
  guests    Int

  // Pricing
  roomRate  Float
  taxes     Float         @default(0)
  totalAmount Float
  currency  Currency      @default(XOF)

  // Commission §6: 10-15%
  commission  Float
  netAmount   Float

  status    BookingStatus @default(PENDING)

  // Source
  source    String        @default("direct") // direct, booking_com, expedia
  otaRef    String?

  // Payment
  paidAt    DateTime?
  paymentRef String?

  hotel     Hotel         @relation(fields: [hotelId], references: [id])
  room      HotelRoom     @relation(fields: [roomId], references: [id])

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("hotel_bookings")
}

// ─────────────────────────────────────────────
// GEOTRUST (§7C CDC)
// ─────────────────────────────────────────────

enum GeoTrustLevel {
  STANDARD
  EXPERT
  ELITE
}

enum GeoServiceCode {
  GEO_GPS
  SURF
  BORN
  INSP
  TOPO
  CONF
  DRON
  CERT
}

enum GeoMissionStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  VALIDATION
  COMPLETED
  CANCELLED
}

model Geometer {
  id           String        @id @default(cuid())
  userId       String        @unique
  displayName  String
  level        GeoTrustLevel @default(STANDARD)
  specialties  GeoServiceCode[]
  country      Country
  city         String
  phone        String?

  // Certification
  certifiedAt  DateTime?
  certScore    Float?
  badgeCode    String?

  // Stats
  totalMissions Int          @default(0)
  avgRating     Float        @default(0)
  isAvailable   Boolean      @default(true)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  missions     GeoTrustMission[]

  @@map("geometers")
}

model GeoTrustMission {
  id           String           @id @default(cuid())
  reference    String           @unique @default(cuid())

  propertyId   String?
  requesterId  String
  geometerId   String?

  serviceCode  GeoServiceCode
  status       GeoMissionStatus @default(PENDING)

  // Location
  country      Country
  city         String
  address      String?
  latitude     Float?
  longitude    Float?

  // Pack
  packName     String?          // Standard, Certification, Drone

  // Pricing
  price        Float
  currency     Currency         @default(XOF)

  // Schedule
  scheduledAt  DateTime?
  completedAt  DateTime?

  // Report
  reportUrl    String?
  surfaceFound Float?           // superficie constatée
  notes        String?

  // Validation
  isValidated  Boolean          @default(false)
  validatedAt  DateTime?

  geometer     Geometer?        @relation(fields: [geometerId], references: [id])

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([requesterId])
  @@index([status])
  @@map("geotrust_missions")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS / HELM (§5.5b / §11 CDC)
// ─────────────────────────────────────────────

enum SubscriptionPlan {
  // HELM Agent plans
  HELM_SEED     // 15,000 FCFA/mois
  HELM_GROW     // 35,000 FCFA/mois
  HELM_LEAD     // 75,000 FCFA/mois
  HELM_NETWORK  // Sur devis

  // PMS Hotel plans
  PMS_STARTER   // 9,900 FCFA/mois
  PMS_PRO       // 24,900 FCFA/mois
  PMS_ENTERPRISE

  // Artisan Pro
  ARTISAN_PRO   // 8,900 FCFA/mois
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String

  plan        SubscriptionPlan
  status      SubscriptionStatus @default(TRIAL)

  // Pricing
  amount      Float
  currency    Currency           @default(XOF)
  billingCycle String            @default("monthly") // monthly, yearly

  // Dates
  startDate   DateTime           @default(now())
  endDate     DateTime?
  trialEnd    DateTime?
  cancelledAt DateTime?

  // Payment
  paymentMethod String?          // mobile_money, card
  fedapayRef    String?
  stripeRef     String?

  // Limits (tracked)
  listingsUsed  Int              @default(0)
  listingsMax   Int              @default(5)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// KYC DOCUMENTS (§5.0 CDC)
// ─────────────────────────────────────────────

enum KYCDocType {
  CNI
  PASSPORT
  PERMIS
  RCCM      // Registre commerce artisan
  PATENTE
  SELFIE
  UTILITY_BILL
}

enum KYCLevel {
  KYC0  // browse only
  KYC1  // 500K XOF/month
  KYC2  // 5M XOF/month
  KYC3  // unlimited
}

model KYCDocument {
  id         String     @id @default(cuid())
  userId     String
  docType    KYCDocType
  url        String     // Cloudflare R2 URL
  fileSize   Int?
  mimeType   String?
  isVerified Boolean    @default(false)
  verifiedAt DateTime?
  verifiedBy String?    // Admin user ID who approved
  rejectedAt DateTime?
  rejectReason String?
  ocrData    Json?      // Extracted OCR fields (confidence, fullName, etc.)

  createdAt  DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isVerified])
  @@map("kyc_documents")
}

// ─────────────────────────────────────────────
// COMMUNITY GAMIFICATION (§5.7 CDC)
// ─────────────────────────────────────────────

enum BadgeType {
  FIRST_LISTING
  VERIFIED_AGENT
  TOP_REVIEWER
  COMMUNITY_STAR
  EARLY_ADOPTER
  SUPER_HOST
  AMBASSADOR
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badge     BadgeType
  awardedAt DateTime  @default(now())
  note      String?

  @@unique([userId, badge])
  @@map("user_badges")
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  points    Int      // positive = earned, negative = spent
  reason    String   // listing_published, review_left, etc.
  refId     String?  // related entity id

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("point_transactions")
}

// ─────────────────────────────────────────────
// AI CHAT (§8 CDC)
// ─────────────────────────────────────────────

model AIChatSession {
  id        String    @id @default(cuid())
  userId    String?   // nullable for anonymous
  channel   String    @default("web") // web, mobile, whatsapp, sms
  messages  Json      // [{role, content, ts}]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("ai_chat_sessions")
}

// ─────────────────────────────────────────────
// AUDIT LOG (§10 CDC — Security)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  // null = system
  action     String   // e.g. "kyc.approved", "escrow.released"
  entity     String?  // e.g. "KYCDocument", "EscrowTransaction"
  entityId   String?
  metadata   Json?    // extra context
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// NOTAIRES CERTIFIÉS AFRIBAYIT (§5.0bis CDC)
// ─────────────────────────────────────────────

enum NotaireCertifStatus {
  PENDING    // Application submitted, under review
  CERTIFIED  // Certified and active
  REJECTED   // Application rejected
  SUSPENDED  // Certification suspended
}

model NotaireProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  ordreNumber      String              // Numéro d'ordre notarial
  chambreNationale String              // Chambre Nationale des Notaires (pays)
  country          Country
  city             String
  address          String?
  bio              String?             @db.Text
  specialties      String[]            @default([]) // OHADA, foncier, immobilier...
  yearsExperience  Int                 @default(0)
  honorairesMin    Int?                // Min FCFA per deed
  honorairesMax    Int?                // Max FCFA per deed
  languages        String[]            @default(["fr"])

  // Certification
  certifStatus     NotaireCertifStatus @default(PENDING)
  certifiedAt      DateTime?
  certifiedBy      String?             // Admin user ID
  rejectedAt       DateTime?
  rejectReason     String?
  conventionSignedAt DateTime?

  // KYC docs submitted for certification
  diplomaUrl       String?             // Diplôme de notariat
  agrémentUrl      String?             // Agrément Chambre Nationale
  carteProUrl      String?             // Carte professionnelle

  // Stats
  totalDossiers    Int                 @default(0)
  avgRating        Float               @default(0)
  totalRevenue     Int                 @default(0) // FCFA

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dossiers         EscrowTransaction[] @relation("NotaireDossier")

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([country])
  @@index([certifStatus])
  @@map("notaire_profiles")
}

// ─────────────────────────────────────────────
// WEB PUSH SUBSCRIPTIONS (§5.8 CDC)
// ─────────────────────────────────────────────

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("web_push_subscriptions")
}

// ─────────────────────────────────────────────
// COMMUNITY FORUM (§5.7 CDC)
// ─────────────────────────────────────────────

enum ForumCategory {
  INVESTISSEMENT
  TEMOIGNAGES
  JURIDIQUE
  CONSEILS
  TRAVAUX
  FINANCE
  GENERAL
}

model ForumPost {
  id         String        @id @default(cuid())
  authorId   String
  title      String
  body       String        @db.Text
  category   ForumCategory @default(GENERAL)
  isPinned   Boolean       @default(false)
  isLocked   Boolean       @default(false)

  author     User          @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies    ForumReply[]
  likes      ForumLike[]

  viewCount  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
  @@map("forum_posts")
}

model ForumReply {
  id        String     @id @default(cuid())
  postId    String
  authorId  String
  body      String     @db.Text
  parentId  String?    // for nested replies

  post      ForumPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User       @relation("ForumReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  likes     ForumLike[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([postId])
  @@index([authorId])
  @@map("forum_replies")
}

model ForumLike {
  id       String      @id @default(cuid())
  userId   String
  postId   String?
  replyId  String?

  user     User        @relation("ForumLikes", fields: [userId], references: [id], onDelete: Cascade)
  post     ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply    ForumReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([userId])
  @@map("forum_likes")
}

// ─────────────────────────────────────────────
// PROMATCH — ARTISAN MISSIONS & QUOTES (§5.5 CDC)
// ─────────────────────────────────────────────

enum MissionStatus {
  OPEN        // posted, awaiting quotes
  QUOTED      // at least one quote received
  ACCEPTED    // client accepted a quote → escrow funded
  IN_PROGRESS // work started
  COMPLETED   // work done, escrow released
  CANCELLED
  EXPIRED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model ArtisanMission {
  id          String        @id @default(cuid())
  clientId    String
  title       String
  description String        @db.Text
  category    ArtisanCategory
  country     Country
  city        String
  budget      Float?        // indicative client budget
  currency    Currency      @default(XOF)
  urgency     String        @default("normal") // urgent | normal | flexible
  status      MissionStatus @default(OPEN)

  // AI matching
  matchedArtisanIds String[]  // top artisan IDs suggested by ProMatch

  // Winning quote
  acceptedQuoteId String?

  client      User          @relation("MissionClient", fields: [clientId], references: [id])
  quotes      ArtisanQuote[]

  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([category])
  @@map("artisan_missions")
}

model ArtisanQuote {
  id          String      @id @default(cuid())
  missionId   String
  artisanId   String      // Artisan.id (not userId)
  amount      Float
  currency    Currency    @default(XOF)
  delay       Int         // estimated days
  description String      @db.Text
  status      QuoteStatus @default(PENDING)

  mission     ArtisanMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  artisan     Artisan        @relation(fields: [artisanId], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([missionId, artisanId])  // one quote per artisan per mission
  @@index([missionId])
  @@index([artisanId])
  @@map("artisan_quotes")
}
