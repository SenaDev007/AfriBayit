generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accounts {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ai_chat_sessions {
  id        String   @id
  userId    String?
  channel   String   @default("web")
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([userId])
}

model artisan_images {
  id        String   @id
  artisanId String
  url       String
  caption   String?
  order     Int      @default(0)
  artisans  artisans @relation(fields: [artisanId], references: [id], onDelete: Cascade)
}

model artisan_missions {
  id                String           @id
  clientId          String
  title             String
  description       String
  category          ArtisanCategory
  country           Country
  city              String
  budget            Float?
  currency          Currency         @default(XOF)
  urgency           String           @default("normal")
  status            MissionStatus    @default(OPEN)
  matchedArtisanIds String[]
  acceptedQuoteId   String?
  expiresAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  users             users            @relation(fields: [clientId], references: [id])
  artisan_quotes    artisan_quotes[]

  @@index([category])
  @@index([clientId])
  @@index([status])
}

model artisan_quotes {
  id               String           @id
  missionId        String
  artisanId        String
  amount           Float
  currency         Currency         @default(XOF)
  delay            Int
  description      String
  status           QuoteStatus      @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  artisans         artisans         @relation(fields: [artisanId], references: [id])
  artisan_missions artisan_missions @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, artisanId])
  @@index([artisanId])
  @@index([missionId])
}

model artisan_services {
  id          String   @id
  artisanId   String
  name        String
  description String?
  basePrice   Float?
  currency    Currency @default(XOF)
  duration    String?
  artisans    artisans @relation(fields: [artisanId], references: [id], onDelete: Cascade)
}

model artisans {
  id               String             @id
  userId           String             @unique
  businessName     String?
  category         ArtisanCategory
  specialty        String[]
  description      String?
  country          Country
  city             String
  serviceArea      String[]
  yearsExp         Int                @default(0)
  isCertified      Boolean            @default(false)
  certifiedAt      DateTime?
  certScore        Float?
  avgRating        Float              @default(0)
  totalReviews     Int                @default(0)
  hourlyRate       Float?
  dailyRate        Float?
  currency         Currency           @default(XOF)
  isAvailable      Boolean            @default(true)
  emergencyService Boolean            @default(false)
  completedJobs    Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  artisan_images   artisan_images[]
  artisan_quotes   artisan_quotes[]
  artisan_services artisan_services[]
  users            users              @relation(fields: [userId], references: [id])
  reviews          reviews[]
}

model audit_logs {
  id        String   @id
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model bookings {
  id                            String        @id
  propertyId                    String
  guestId                       String
  hostId                        String
  checkIn                       DateTime
  checkOut                      DateTime
  nights                        Int
  guests                        Int
  nightlyRate                   Float
  totalAmount                   Float
  serviceFee                    Float
  hostAmount                    Float
  currency                      Currency      @default(XOF)
  status                        BookingStatus @default(PENDING)
  paidAt                        DateTime?
  paymentRef                    String?
  paymentMethod                 String?
  guestNote                     String?
  hostNote                      String?
  checkInCode                   String?
  checkedInAt                   DateTime?
  checkedOutAt                  DateTime?
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime
  users_bookings_guestIdTousers users         @relation("bookings_guestIdTousers", fields: [guestId], references: [id])
  users_bookings_hostIdTousers  users         @relation("bookings_hostIdTousers", fields: [hostId], references: [id])
  properties                    properties    @relation(fields: [propertyId], references: [id])
  transactions                  transactions?
}

model course_modules {
  id       String  @id
  courseId String
  title    String
  order    Int
  videoUrl String?
  duration Int?
  courses  courses @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model courses {
  id             String           @id
  title          String
  description    String
  slug           String           @unique
  level          CourseLevel      @default(BEGINNER)
  category       String
  language       String           @default("fr")
  price          Float            @default(0)
  currency       Currency         @default(XOF)
  thumbnailUrl   String?
  videoUrl       String?
  duration       Int?
  isPublished    Boolean          @default(false)
  isCertified    Boolean          @default(false)
  instructorId   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  course_modules course_modules[]
  enrollments    enrollments[]
}

model enrollments {
  id          String    @id
  userId      String
  courseId    String
  progress    Float     @default(0)
  completedAt DateTime?
  certUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  courses     courses   @relation(fields: [courseId], references: [id])
  users       users     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model escrow_transactions {
  id                                        String            @id
  reference                                 String            @unique
  type                                      EscrowType
  state                                     EscrowState       @default(CREATED)
  buyerId                                   String
  sellerId                                  String
  amount                                    Float
  commission                                Float
  netAmount                                 Float
  currency                                  Currency          @default(XOF)
  propertyId                                String?
  bookingId                                 String?
  artisanJobId                              String?
  paymentMethod                             String?
  paymentRef                                String?
  fedapayRef                                String?
  fundedAt                                  DateTime?
  startedAt                                 DateTime?
  validationAt                              DateTime?
  releasedAt                                DateTime?
  refundedAt                                DateTime?
  expiresAt                                 DateTime?
  buyerValidated                            Boolean           @default(false)
  sellerValidated                           Boolean           @default(false)
  disputeReason                             String?
  stateHistory                              Json?
  createdAt                                 DateTime          @default(now())
  updatedAt                                 DateTime
  deedHash                                  String?
  deedSignedAt                              DateTime?
  deedUrl                                   String?
  notaireId                                 String?
  users_escrow_transactions_buyerIdTousers  users             @relation("escrow_transactions_buyerIdTousers", fields: [buyerId], references: [id])
  notaire_profiles                          notaire_profiles? @relation(fields: [notaireId], references: [id])
  users_escrow_transactions_sellerIdTousers users             @relation("escrow_transactions_sellerIdTousers", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([notaireId])
  @@index([sellerId])
  @@index([state])
}

model favorites {
  id         String     @id
  userId     String
  propertyId String
  createdAt  DateTime   @default(now())
  properties properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  users      users      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model forum_likes {
  id            String         @id
  userId        String
  postId        String?
  replyId       String?
  createdAt     DateTime       @default(now())
  forum_posts   forum_posts?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  forum_replies forum_replies? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  users         users          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([userId])
}

model forum_posts {
  id            String          @id
  authorId      String
  title         String
  body          String
  category      ForumCategory   @default(GENERAL)
  isPinned      Boolean         @default(false)
  isLocked      Boolean         @default(false)
  viewCount     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  forum_likes   forum_likes[]
  users         users           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum_replies forum_replies[]

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
}

model forum_replies {
  id          String        @id
  postId      String
  authorId    String
  body        String
  parentId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  forum_likes forum_likes[]
  users       users         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum_posts forum_posts   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([postId])
}

model geometers {
  id                String              @id
  userId            String              @unique
  displayName       String
  level             GeoTrustLevel       @default(STANDARD)
  specialties       GeoServiceCode[]
  country           Country
  city              String
  phone             String?
  certifiedAt       DateTime?
  certScore         Float?
  badgeCode         String?
  totalMissions     Int                 @default(0)
  avgRating         Float               @default(0)
  isAvailable       Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  geotrust_missions geotrust_missions[]
}

model geotrust_missions {
  id           String           @id
  reference    String           @unique
  propertyId   String?
  requesterId  String
  geometerId   String?
  serviceCode  GeoServiceCode
  status       GeoMissionStatus @default(PENDING)
  country      Country
  city         String
  address      String?
  latitude     Float?
  longitude    Float?
  packName     String?
  price        Float
  currency     Currency         @default(XOF)
  scheduledAt  DateTime?
  completedAt  DateTime?
  reportUrl    String?
  surfaceFound Float?
  notes        String?
  isValidated  Boolean          @default(false)
  validatedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime
  geometers    geometers?       @relation(fields: [geometerId], references: [id])

  @@index([requesterId])
  @@index([status])
}

model guesthouse_bookings {
  id               String           @id
  guesthouseId     String
  roomId           String
  guestId          String
  checkIn          DateTime
  checkOut         DateTime
  nights           Int
  guests           Int
  baseAmount       Float
  finalAmount      Float
  currency         Currency         @default(XOF)
  includeBreakfast Boolean          @default(false)
  breakfastAmount  Float?
  status           BookingStatus    @default(PENDING)
  paidAt           DateTime?
  paymentRef       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  guesthouses      guesthouses      @relation(fields: [guesthouseId], references: [id])
  guesthouse_rooms guesthouse_rooms @relation(fields: [roomId], references: [id])
}

model guesthouse_images {
  id           String      @id
  guesthouseId String
  url          String
  alt          String?
  order        Int         @default(0)
  isPrimary    Boolean     @default(false)
  guesthouses  guesthouses @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)
}

model guesthouse_pricing_rules {
  id           String      @id
  guesthouseId String
  name         String
  startDate    DateTime
  endDate      DateTime
  multiplier   Float
  description  String?
  guesthouses  guesthouses @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)
}

model guesthouse_room_images {
  id               String           @id
  roomId           String
  url              String
  alt              String?
  order            Int              @default(0)
  guesthouse_rooms guesthouse_rooms @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model guesthouse_rooms {
  id                     String                   @id
  guesthouseId           String
  name                   String
  description            String?
  capacity               Int                      @default(2)
  bedType                String?
  basePrice              Float
  currency               Currency                 @default(XOF)
  amenities              Json?
  isAvailable            Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  guesthouse_bookings    guesthouse_bookings[]
  guesthouse_room_images guesthouse_room_images[]
  guesthouses            guesthouses              @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)
}

model guesthouse_staff {
  id           String      @id
  guesthouseId String
  name         String
  role         String
  phone        String?
  accessLevel  String      @default("limited")
  createdAt    DateTime    @default(now())
  guesthouses  guesthouses @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)
}

model guesthouses {
  id                       String                     @id
  name                     String
  description              String
  slug                     String                     @unique
  country                  Country
  city                     String
  district                 String?
  address                  String?
  latitude                 Float?
  longitude                Float?
  hasBreakfast             Boolean                    @default(false)
  hasParking               Boolean                    @default(false)
  hasWifi                  Boolean                    @default(true)
  hasAC                    Boolean                    @default(false)
  hasPool                  Boolean                    @default(false)
  isCertified              Boolean                    @default(false)
  certifiedAt              DateTime?
  certScore                Float?
  avgRating                Float                      @default(0)
  totalReviews             Int                        @default(0)
  isActive                 Boolean                    @default(true)
  ownerId                  String
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime
  guesthouse_bookings      guesthouse_bookings[]
  guesthouse_images        guesthouse_images[]
  guesthouse_pricing_rules guesthouse_pricing_rules[]
  guesthouse_rooms         guesthouse_rooms[]
  guesthouse_staff         guesthouse_staff[]
  users                    users                      @relation(fields: [ownerId], references: [id])
  reviews                  reviews[]
}

model hotel_bookings {
  id          String        @id
  hotelId     String
  roomId      String
  guestId     String
  checkIn     DateTime
  checkOut    DateTime
  nights      Int
  guests      Int
  roomRate    Float
  taxes       Float         @default(0)
  totalAmount Float
  currency    Currency      @default(XOF)
  commission  Float
  netAmount   Float
  status      BookingStatus @default(PENDING)
  source      String        @default("direct")
  otaRef      String?
  paidAt      DateTime?
  paymentRef  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  hotels      hotels        @relation(fields: [hotelId], references: [id])
  hotel_rooms hotel_rooms   @relation(fields: [roomId], references: [id])
}

model hotel_images {
  id        String  @id
  hotelId   String
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
  hotels    hotels  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model hotel_room_images {
  id          String      @id
  roomId      String
  url         String
  alt         String?
  order       Int         @default(0)
  hotel_rooms hotel_rooms @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model hotel_rooms {
  id                String              @id
  hotelId           String
  name              String
  description       String?
  roomCode          String?
  capacity          Int                 @default(2)
  bedType           String?
  floor             Int?
  basePrice         Float
  currency          Currency            @default(XOF)
  amenities         Json?
  isAvailable       Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  hotel_bookings    hotel_bookings[]
  hotel_room_images hotel_room_images[]
  hotels            hotels              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model hotels {
  id             String           @id
  name           String
  description    String
  slug           String           @unique
  networkType    HotelNetworkType @default(DIRECT)
  plan           HotelPlan?
  bookingComId   String?
  otaIds         Json?
  country        Country
  city           String
  district       String?
  address        String?
  latitude       Float?
  longitude      Float?
  stars          Int              @default(3)
  category       String?
  hasPool        Boolean          @default(false)
  hasRestaurant  Boolean          @default(false)
  hasSpa         Boolean          @default(false)
  hasGym         Boolean          @default(false)
  hasConference  Boolean          @default(false)
  hasParking     Boolean          @default(false)
  hasWifi        Boolean          @default(true)
  hasAC          Boolean          @default(true)
  avgRating      Float            @default(0)
  totalReviews   Int              @default(0)
  isActive       Boolean          @default(true)
  isVerified     Boolean          @default(false)
  ownerId        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  hotel_bookings hotel_bookings[]
  hotel_images   hotel_images[]
  hotel_rooms    hotel_rooms[]

  @@index([country, city])
}

model kyc_documents {
  id           String     @id
  userId       String
  docType      KYCDocType
  url          String
  fileSize     Int?
  mimeType     String?
  isVerified   Boolean    @default(false)
  verifiedAt   DateTime?
  rejectedAt   DateTime?
  rejectReason String?
  createdAt    DateTime   @default(now())
  verifiedBy   String?
  ocrData      Json?
  users        users      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified])
  @@index([userId])
}

model ledger_entries {
  id            String          @id
  escrowId      String?
  entryType     LedgerEntryType
  debitAccount  String
  creditAccount String
  amount        Float
  currency      Currency        @default(XOF)
  description   String
  prevHash      String?
  hash          String?
  createdAt     DateTime        @default(now())

  @@index([createdAt])
  @@index([creditAccount])
  @@index([debitAccount])
  @@index([escrowId])
}

model messages {
  id                               String   @id
  senderId                         String
  receiverId                       String
  content                          String
  isRead                           Boolean  @default(false)
  createdAt                        DateTime @default(now())
  users_messages_receiverIdTousers users    @relation("messages_receiverIdTousers", fields: [receiverId], references: [id])
  users_messages_senderIdTousers   users    @relation("messages_senderIdTousers", fields: [senderId], references: [id])
}

model notaire_profiles {
  id                  String                @id
  userId              String                @unique
  ordreNumber         String
  chambreNationale    String
  country             Country
  city                String
  address             String?
  bio                 String?
  specialties         String[]              @default([])
  yearsExperience     Int                   @default(0)
  honorairesMin       Int?
  honorairesMax       Int?
  languages           String[]              @default(["fr"])
  certifStatus        NotaireCertifStatus   @default(PENDING)
  certifiedAt         DateTime?
  certifiedBy         String?
  rejectedAt          DateTime?
  rejectReason        String?
  conventionSignedAt  DateTime?
  diplomaUrl          String?
  agr_mentUrl         String?               @map("agrémentUrl")
  carteProUrl         String?
  totalDossiers       Int                   @default(0)
  avgRating           Float                 @default(0)
  totalRevenue        Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  escrow_transactions escrow_transactions[]
  users               users                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([certifStatus])
  @@index([country])
}

model notifications {
  id        String   @id
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  href      String?
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model onboarding_profiles {
  id          String   @id
  userId      String   @unique
  profileType String
  country     String?
  city        String?
  interests   String[]
  budget      String?
  notifEmail  Boolean  @default(true)
  notifSMS    Boolean  @default(false)
  notifPush   Boolean  @default(true)
  notifNews   Boolean  @default(false)
  completedAt DateTime @default(now())
}

model point_transactions {
  id        String   @id
  userId    String
  points    Int
  reason    String
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model price_history {
  id         String     @id
  propertyId String
  price      Float
  currency   Currency
  date       DateTime   @default(now())
  properties properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model properties {
  id              String                 @id
  title           String
  description     String
  slug            String                 @unique
  type            PropertyType
  listingType     ListingType
  status          PropertyStatus         @default(DRAFT)
  price           Float
  priceUnit       String                 @default("FCFA")
  currency        Currency               @default(XOF)
  country         Country
  city            String
  district        String?
  address         String?
  latitude        Float?
  longitude       Float?
  surface         Float?
  bedrooms        Int?
  bathrooms       Int?
  floors          Int?
  yearBuilt       Int?
  hasGarage       Boolean                @default(false)
  hasPool         Boolean                @default(false)
  hasGarden       Boolean                @default(false)
  hasBalcony      Boolean                @default(false)
  hasSecurity     Boolean                @default(false)
  hasGenerator    Boolean                @default(false)
  hasWifi         Boolean                @default(false)
  hasAC           Boolean                @default(false)
  features        Json?
  viewCount       Int                    @default(0)
  favoriteCount   Int                    @default(0)
  investmentScore Float?
  virtualTourUrl  String?
  matterportId    String?
  ownerId         String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime
  publishedAt     DateTime?
  legalDocStatus  String                 @default("PENDING")
  legalDocType    String?
  legalDocUrl     String?
  embedding       Unsupported("vector")?
  bookings        bookings[]
  favorites       favorites[]
  price_history   price_history[]
  users           users                  @relation(fields: [ownerId], references: [id])
  property_images property_images[]
  reviews         reviews[]

  @@index([country, city])
  @@index([price])
  @@index([type, listingType])
}

model property_images {
  id         String     @id
  propertyId String
  url        String
  alt        String?
  order      Int        @default(0)
  isPrimary  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  properties properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model reviews {
  id                            String       @id
  authorId                      String
  targetId                      String?
  propertyId                    String?
  guesthouseId                  String?
  artisanId                     String?
  rating                        Int
  title                         String?
  comment                       String?
  isVerified                    Boolean      @default(false)
  createdAt                     DateTime     @default(now())
  artisans                      artisans?    @relation(fields: [artisanId], references: [id])
  users_reviews_authorIdTousers users        @relation("reviews_authorIdTousers", fields: [authorId], references: [id])
  guesthouses                   guesthouses? @relation(fields: [guesthouseId], references: [id])
  properties                    properties?  @relation(fields: [propertyId], references: [id])
  users_reviews_targetIdTousers users?       @relation("reviews_targetIdTousers", fields: [targetId], references: [id])
}

model sessions {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model subscriptions {
  id            String             @id
  userId        String
  plan          SubscriptionPlan
  status        SubscriptionStatus @default(TRIAL)
  amount        Float
  currency      Currency           @default(XOF)
  billingCycle  String             @default("monthly")
  startDate     DateTime           @default(now())
  endDate       DateTime?
  trialEnd      DateTime?
  cancelledAt   DateTime?
  paymentMethod String?
  fedapayRef    String?
  stripeRef     String?
  listingsUsed  Int                @default(0)
  listingsMax   Int                @default(5)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime

  @@index([userId])
}

model transactions {
  id            String            @id
  bookingId     String?           @unique
  senderId      String
  receiverId    String
  amount        Float
  commission    Float
  netAmount     Float
  currency      Currency          @default(XOF)
  status        TransactionStatus @default(PENDING)
  type          String
  inEscrow      Boolean           @default(false)
  escrowAt      DateTime?
  releasedAt    DateTime?
  paymentMethod String?
  paymentRef    String?
  fedapayRef    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime
  bookings      bookings?         @relation(fields: [bookingId], references: [id])
  users         users             @relation(fields: [senderId], references: [id])
}

model user_badges {
  id        String    @id
  userId    String
  badge     BadgeType
  awardedAt DateTime  @default(now())
  note      String?

  @@unique([userId, badge])
}

model users {
  id                                                      String                @id
  email                                                   String?               @unique
  phone                                                   String?               @unique
  emailVerified                                           DateTime?
  phoneVerified                                           DateTime?
  name                                                    String?
  firstName                                               String?
  lastName                                                String?
  image                                                   String?
  password                                                String?
  userType                                                UserType              @default(BUYER)
  status                                                  UserStatus            @default(PENDING)
  kycStatus                                               KYCStatus             @default(NONE)
  country                                                 Country?
  city                                                    String?
  address                                                 String?
  bio                                                     String?
  language                                                String                @default("fr")
  reputationScore                                         Int                   @default(500)
  totalReviews                                            Int                   @default(0)
  isPremium                                               Boolean               @default(false)
  premiumUntil                                            DateTime?
  loyaltyPoints                                           Int                   @default(0)
  createdAt                                               DateTime              @default(now())
  updatedAt                                               DateTime
  lastLoginAt                                             DateTime?
  kycLevel                                                KYCLevel              @default(KYC0)
  kycMonthReset                                           DateTime?
  kycMonthlySpent                                         Int                   @default(0)
  accounts                                                accounts[]
  artisan_missions                                        artisan_missions[]
  artisans                                                artisans?
  bookings_bookings_guestIdTousers                        bookings[]            @relation("bookings_guestIdTousers")
  bookings_bookings_hostIdTousers                         bookings[]            @relation("bookings_hostIdTousers")
  enrollments                                             enrollments[]
  escrow_transactions_escrow_transactions_buyerIdTousers  escrow_transactions[] @relation("escrow_transactions_buyerIdTousers")
  escrow_transactions_escrow_transactions_sellerIdTousers escrow_transactions[] @relation("escrow_transactions_sellerIdTousers")
  favorites                                               favorites[]
  forum_likes                                             forum_likes[]
  forum_posts                                             forum_posts[]
  forum_replies                                           forum_replies[]
  guesthouses                                             guesthouses[]
  kyc_documents                                           kyc_documents[]
  messages_messages_receiverIdTousers                     messages[]            @relation("messages_receiverIdTousers")
  messages_messages_senderIdTousers                       messages[]            @relation("messages_senderIdTousers")
  notaire_profiles                                        notaire_profiles?
  notifications                                           notifications[]
  properties                                              properties[]
  reviews_reviews_authorIdTousers                         reviews[]             @relation("reviews_authorIdTousers")
  reviews_reviews_targetIdTousers                         reviews[]             @relation("reviews_targetIdTousers")
  sessions                                                sessions[]
  transactions                                            transactions[]
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model web_push_subscriptions {
  id        String   @id
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

