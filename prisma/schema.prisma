// AfriBayit — Prisma Schema V2
// Plateforme Immobilière Pan-Africaine de Nouvelle Génération
// Complet selon CDC V3.1 — Toutes sections intégrées

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  name          String
  firstName     String?
  lastName      String?
  avatar        String?
  coverPhoto    String?
  password      String?
  role          String   @default("buyer") // buyer, seller, investor, tourist, artisan, agent, notary, geometer, admin, hotelier, trainer, certified_agent, premium_agent, artisan_pro
  country       String?  // BJ, CI, BF, TG
  city          String?
  kycLevel      Int      @default(0) // 0=Anonyme, 1=Standard, 2=Avancé, 3=Pro
  score         Int      @default(0) // 0-1000 reputation score
  reputation    String   @default("Decouvreur") // Decouvreur, Acteur, Expert, Ambassadeur
  bio           String?
  specialties   String?  // JSON array
  emailVerified     DateTime? // When email was verified (null = not verified)
  phoneVerified     DateTime? // When phone was verified (null = not verified)
  verified          Boolean  @default(false)
  verificationStatus String   @default("PENDING") // PENDING, APPROVED, REJECTED — agent certification status
  premiumTier   String?  // starter, essentiel, avance, elite
  premiumExpiry DateTime?
  walletBalance Float    @default(0)
  escrowHeld    Float    @default(0)
  pendingPayout Float    @default(0)
  afriPoints    Int      @default(0)
  credibilityScore Int   @default(0) // 0-100 score de crédibilité profil LinkedIn-like
  isOnline      Boolean  @default(false)
  lastSeenAt    DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  preferredLanguage String @default("fr") // fr, en, sw, ha, wo, ar
  currency      String   @default("XOF") // XOF, EUR, USD, NGN, GHS, KES
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties       Property[]
  transactions     Transaction[]
  listings         AgentListing[]
  reviews          Review[]
  courses          CourseEnrollment[]
  posts            CommunityPost[]
  notifications    Notification[]
  oauthAccounts    OAuthAccount[]
  kycDocuments     KycDocument[]
  pushSubscriptions PushSubscription[]
  walletTxns       WalletTransaction[]
  subscriptions    Subscription[]
  professionalProfile ProfessionalProfile?
  endorsements     SkillEndorsement[]
  sentMessages     ChatMessage[]       @relation("SentMessages")
  conversations    ConversationParticipant[]
  favorites        Favorite[]
  profileViews     ProfileView[]       @relation("ProfileViewed")
  viewerProfiles   ProfileView[]       @relation("ProfileViewer")
  connections      UserConnection[]    @relation("Requester")
  connectedTo      UserConnection[]    @relation("Target")
  hotelBookings    HotelBooking[]
  guesthouseBookings GuesthouseBooking[]
  shortTermRentalBookings ShortTermRentalBooking[]
  accreditations   CountryAccreditation[]
  quizAttempts     QuizAttempt[]
  certificates     Certificate[]
  afriPointTxns    AfriPointTransaction[]
  ambassador       Ambassador?
  notary           Notary?
  geometer         Geometer?
  following         Follower[]    @relation("Following")
  followers         Follower[]    @relation("Followers")

  @@map("users")
}

model OAuthAccount {
  id           String   @id @default(cuid())
  provider     String   // google, facebook, apple
  providerId   String
  userId       String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model KycDocument {
  id            String   @id @default(cuid())
  userId        String
  docType       String   // id_card, passport, selfie, proof_address, income_source, rccm, company_statutes, agent_license, notary_license, geometer_license, business_reg
  docUrl        String
  ocrResult     String?  // JSON: OCR extracted data
  ocrValid      Boolean  @default(false)
  aiScore       Float?   // 0-100 AI validation score
  status        String   @default("pending") // pending, ai_validated, human_validated, rejected
  rejectionReason String?
  country       String?  // BJ, CI, BF, TG
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

// ============ PUSH SUBSCRIPTIONS ============

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// ============ OTP VERIFICATION ============

model OtpVerification {
  id         String   @id @default(cuid())
  identifier String   // phone or email
  code       String   // 6-digit OTP code
  type       String   // phone, email
  verified   Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier, code])
  @@map("otp_verifications")
}

// ============ PROPERTIES ============

model Property {
  id           String   @id @default(cuid())
  title        String
  slug         String?  @unique
  type         String   // villa, appartement, terrain, bureau, commerce, chambre, guesthouse
  transaction  String   // achat, location, investissement, location_courte_duree
  price        Float
  currency     String   @default("XOF")
  surface      Float
  rooms        Int      @default(0)
  bedrooms     Int      @default(0)
  bathrooms    Int      @default(0)
  city         String
  country      String
  quartier     String
  address      String?
  description  String
  features     String?  // JSON array
  images       String?  // JSON array of URLs
  lat          Float?
  lng          Float?
  /// PostGIS geometry field — requires PostGIS extension. Use createPoint() from @/lib/geo/postgis for writes.
  geometry     Unsupported("geometry(Point, 4326)")?
  /// Full-text search vector (PostgreSQL tsvector) — used for ts_rank and ts_query searches
  searchVector Unsupported("tsvector")?
  verified     Boolean  @default(false)
  geoTrust     Boolean  @default(false)
  geoTrustLevel String?  // standard, expert, elite
  premium      Boolean  @default(false)
  status       String   @default("draft") // draft, pending, pending_validation, ai_review, human_review, published, sold, rented, rejected
  views        Int      @default(0)
  favorites    Int      @default(0)
  agentId      String
  investmentScore Int?  // 0-100 score investissement IA
  walkScore    Float?   // 0-100 walkability score
  hasVR        Boolean  @default(false)
  hasDroneView Boolean  @default(false)
  rejectionReason String?
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner          User              @relation(fields: [agentId], references: [id])
  transactionRecords Transaction[]
  propertyImages PropertyImage[]
  virtualTours  VirtualTour[]
  legalDocs     PropertyLegalDoc[]
  geoInspections GeoInspection[]
  geometerMissions GeometerMission[] @relation("PropertyMissions")
  favorites_rel Favorite[]
  comparisons   PropertyComparison[]  @relation("PropertyA")
  comparisons2  PropertyComparison[]  @relation("PropertyB")

  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  url         String
  alt         String?
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)
  uploadedAt  DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model VirtualTour {
  id          String   @id @default(cuid())
  propertyId  String
  tourType    String   // matterport, 360_photo, drone, video
  url         String
  thumbnailUrl String?
  duration    Int?     // seconds for video
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("virtual_tours")
}

model PropertyLegalDoc {
  id          String   @id @default(cuid())
  propertyId  String
  docType     String   // titre_foncier, acd, permis_construire, decision_parcelle, lettre_attribution, arrete_concession, puh, acte_cession, certificat_propriete_andf
  docUrl      String
  ocrValid    Boolean  @default(false)
  aiScore     Float?   // 0-100 AI validation
  status      String   @default("pending") // pending, ai_validated, human_validated, rejected
  country     String   // BJ, CI, BF, TG — determines required docs
  rejectionReason String?
  uploadedAt  DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_legal_docs")
}

model PropertyComparison {
  id          String   @id @default(cuid())
  userId      String
  propertyAId String
  propertyBId String
  propertyCId String?  // optional 3rd property
  propertyDId String?  // optional 4th property
  propertyEId String?  // optional 5th property
  createdAt   DateTime @default(now())

  propertyA   Property @relation("PropertyA", fields: [propertyAId], references: [id])
  propertyB   Property @relation("PropertyB", fields: [propertyBId], references: [id])

  @@map("property_comparisons")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

// ============ NOTARIES ============

model Notary {
  id              String   @id @default(cuid())
  userId          String   @unique
  licenseNumber   String   @unique
  chamberName     String?  // Chambre Nationale des Notaires
  specialty       String?  // droit_foncier, succession, baux, etc.
  certificationLevel String @default("standard") // standard, expert, elite
  country         String   @default("BJ") // BJ, CI, BF, TG — pays d'exercice
  zone            String?  // zone d'intervention
  available       Boolean  @default(true)
  rating          Float    @default(0)
  missions        Int      @default(0)
  subscriptionTier String?  // gratuit, pro, elite
  subscriptionExpiry DateTime?
  conventionSigned Boolean @default(false)
  conventionUrl   String?
  certified       Boolean  @default(false)
  certifiedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notaries")
}

// ============ TRANSACTIONS & ESCROW ============

model Transaction {
  id              String   @id @default(cuid())
  propertyId      String
  buyerId         String
  sellerId        String
  amount          Float
  commission      Float    @default(0)
  currency        String   @default("XOF")
  country         String   @default("BJ") // BJ, CI, BF, TG — pays de la transaction
  status          String   @default("CREATED") // CREATED, FUNDED, DOCS_VALIDATED, GEOTRUST_VALIDATED, NOTARY_ASSIGNED, NOTARY_IN_PROGRESS, DEED_SIGNED, ANDF_REGISTERED, RELEASED, DISPUTED, REFUNDED, EXPIRED
  escrowReference String?
  paymentProvider String?
  paymentRef      String?
  conditions      String?  // JSON: release conditions config
  notaryId        String?
  geometerId      String?
  disputeReason   String?
  escrowFundedAt  DateTime?
  escrowReleasedAt DateTime?
  notaryAssignedAt DateTime?
  deedSignedAt    DateTime?
  andfRegisteredAt DateTime?
  ledgerEntries   String?  // JSON array of ledger entry references
  commissionRate  Float?   // 2-5% selon montant
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id])
  buyer           User     @relation(fields: [buyerId], references: [id])
  escrowAccount   EscrowAccount?
  timelineEvents  TransactionTimeline[]

  @@map("transactions")
}

model EscrowAccount {
  id              String   @id @default(cuid())
  transactionId   String   @unique
  balance         Float    @default(0)
  heldAmount      Float    @default(0)
  releasedAmount  Float    @default(0)
  refundedAmount  Float    @default(0)
  currency        String   @default("XOF")
  status          String   @default("EMPTY") // EMPTY, FUNDED, PARTIAL_RELEASE, FULL_RELEASE, REFUNDED, DISPUTED
  fundedAt        DateTime?
  releasedAt      DateTime?
  refundedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     Transaction @relation(fields: [transactionId], references: [id])
  ledger          EscrowLedger[]

  @@map("escrow_accounts")
}

model EscrowLedger {
  id              String   @id @default(cuid())
  escrowAccountId String
  entryType       String   // CREDIT, DEBIT, HOLD, RELEASE, REFUND, COMMISSION
  amount          Float
  balanceAfter    Float
  currency        String   @default("XOF")
  reference       String?
  providerRef     String?
  metadata        String?  // JSON: additional context
  createdAt       DateTime @default(now())

  escrowAccount   EscrowAccount @relation(fields: [escrowAccountId], references: [id], onDelete: Cascade)

  @@map("escrow_ledger")
}

model TransactionTimeline {
  id            String   @id @default(cuid())
  transactionId String
  fromStatus    String
  toStatus      String
  actorType     String   // system, buyer, seller, notary, geometer, admin
  actorId       String?
  description   String
  metadata      String?  // JSON
  createdAt     DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_timeline")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // deposit, withdrawal, escrow_fund, escrow_release, escrow_refund, commission, payout, subscription, academy_payment
  amount      Float
  balanceAfter Float
  currency    String   @default("XOF")
  status      String   @default("pending") // pending, completed, failed
  reference   String?
  providerRef String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

// ============ AGENT LISTINGS ============

model AgentListing {
  id          String   @id @default(cuid())
  agentId     String
  propertyId  String
  status      String   @default("active")
  boostLevel  Float    @default(1.0) // 1.0, 1.5, 2.5, 4.0 based on premium tier
  views       Int      @default(0)
  contacts    Int      @default(0)
  createdAt   DateTime @default(now())

  agent       User     @relation(fields: [agentId], references: [id])

  @@map("agent_listings")
}

// ============ REVIEWS ============

model Review {
  id          String   @id @default(cuid())
  reviewerId  String
  targetId    String
  targetType  String   // agent, artisan, property, geometer, notary, hotel, course
  country     String?  // BJ, CI, BF, TG
  rating      Int      // 1-5
  subRatings  String?  // JSON: {cleanliness, comfort, location, value, service} for hotels
  comment     String?
  verified    Boolean  @default(false)
  response    String?  // owner response
  respondedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviewer    User     @relation(fields: [reviewerId], references: [id])

  @@map("reviews")
}

// ============ COURSES & ACADEMY ============

model Course {
  id            String   @id @default(cuid())
  title         String
  slug          String?  @unique
  category      String   // immobilier, droit_foncier, investissement, construction, finance, certification
  country       String   @default("BJ") // BJ, CI, BF, TG — marché cible
  instructorId  String
  instructor    String
  description   String?
  duration      String
  price         Float    @default(0)
  currency      String   @default("XOF")
  level         String   @default("debutant") // debutant, intermediaire, avance, expert
  certificate   Boolean  @default(false)
  certificateTemplate String?
  rating        Float    @default(0)
  students      Int      @default(0)
  image         String?
  videoUrl      String?
  published     Boolean  @default(false)
  modules       String?  // JSON array of module objects
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments   CourseEnrollment[]
  quizzes       Quiz[]
  certificates_rel Certificate[]

  @@map("courses")
}

model CourseEnrollment {
  id            String   @id @default(cuid())
  userId        String
  courseId      String
  progress      Float    @default(0)
  completed     Boolean  @default(false)
  certificateId String?
  certificateUrl String?
  enrolledAt    DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

// ============ COMMUNITY ============

model CommunityPost {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  content     String?
  category    String   // discussion, question, success_story, market_analysis, legal, event, investment
  country     String?
  replies     Int      @default(0)
  views       Int      @default(0)
  likes       Int      @default(0)
  pinned      Boolean  @default(false)
  tags        String?  // JSON array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User            @relation(fields: [authorId], references: [id])
  replies_rel CommunityReply[]
  likes_rel   PostLike[]

  @@map("community_posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model CommunityReply {
  id          String   @id @default(cuid())
  postId      String
  authorId    String
  content     String
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("community_replies")
}

model CommunityGroup {
  id          String   @id @default(cuid())
  name        String
  slug        String?  @unique
  description String?
  type        String   // investisseurs, agents, artisans, ville, pays, theme
  country     String?
  city        String?
  members     Int      @default(0)
  isPrivate   Boolean  @default(false)
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships GroupMembership[]

  @@map("community_groups")
}

model GroupMembership {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") // member, moderator, admin
  joinedAt  DateTime @default(now())

  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_memberships")
}

model CommunityEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  organizerId String
  groupId     String?
  eventType   String   // meetup, webinar, formation, visite
  country     String?  // BJ, CI, BF, TG
  city        String?
  venue       String?
  eventDate   DateTime
  endDate     DateTime?
  isVirtual   Boolean  @default(false)
  meetingUrl  String?
  maxAttendees Int?
  attendees   Int      @default(0)
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registrations EventRegistration[]

  @@map("community_events")
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event     CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_registrations")
}

// ============ NOTIFICATIONS ============

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // transaction, message, alert, system, promotion, community, rebecca, certification, profile, premium, security
  category    String   // profile, annonces, transactions, market_alerts, rebecca, community, formations, certification, premium, security
  country     String?  // BJ, CI, BF, TG — pays concerné
  title       String
  message     String
  read        Boolean  @default(false)
  actionUrl   String?
  actorId     String?  // who triggered this notification
  actorName   String?
  metadata    String?  // JSON: additional context
  channels    String?  // JSON array: push, email, sms, whatsapp
  sentVia     String?  // JSON array of channels already sent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  readAt      DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============ ARTISANS ============

model Artisan {
  id          String   @id @default(cuid())
  userId      String   @unique
  trade       String
  specialties String?  // JSON array
  certified   Boolean  @default(false)
  kybValid    Boolean  @default(false)
  available   Boolean  @default(true)
  emergency   Boolean  @default(false)
  priceRange  String?
  dailyRate   Float?
  portfolio   String?  // JSON array of images
  rating      Float    @default(0)
  reviews     Int      @default(0)
  zone        String?
  city        String?
  country     String?
  subscriptionTier String? // gratuit, pro
  responseTime Int?    // average response time in minutes
  completedMissions Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services    ArtisanService[]
  quotes      ArtisanQuote[]

  @@map("artisans")
}

model ArtisanService {
  id          String   @id @default(cuid())
  artisanId   String
  serviceName String
  description String?
  basePrice   Float?
  unit        String?  // m2, hour, day, forfait
  category    String?  // gros_oeuvre, second_oeuvre, finition, genie_technique, exterieur, renovation, numerique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artisan     Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("artisan_services")
}

model ArtisanQuote {
  id          String   @id @default(cuid())
  artisanId   String
  userId      String
  propertyId  String?
  title       String
  description String
  estimatedBudget Float?
  status      String   @default("requested") // requested, sent, accepted, rejected, in_progress, completed
  artisanResponse String?
  quotedPrice Float?
  quotedDuration String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artisan     Artisan  @relation(fields: [artisanId], references: [id])

  @@map("artisan_quotes")
}

// ============ GEOTRUST ============

model Geometer {
  id              String   @id @default(cuid())
  userId          String   @unique
  licenseNumber   String   @unique
  specialities    String?  // JSON array: GEO_SURF, GEO_INSP, GEO_BORN, GEO_TOPO, GEO_DRON, GEO_CERT, GEO_GPS, GEO_3D
  certificationLevel String @default("standard") // standard, expert, elite
  zone            String?
  city            String?
  country         String?
  available       Boolean  @default(true)
  rating          Float    @default(0)
  missions        Int      @default(0)
  lat             Float?
  lng             Float?
  subscriptionTier String? // gratuit, pro
  certified       Boolean  @default(false)
  certifiedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions_rel    GeometerMission[]

  @@map("geometers")
}

model GeometerMission {
  id              String   @id @default(cuid())
  propertyId      String
  geometerId      String
  serviceCode     String   // GEO_GPS, GEO_SURF, GEO_INSP, GEO_BORN, GEO_TOPO, GEO_DRON, GEO_CERT, GEO_3D
  status          String   @default("requested") // requested, assigned, scheduled, in_progress, completed, cancelled
  scheduledAt     DateTime?
  completedAt     DateTime?
  price           Float
  currency        String   @default("XOF")
  reportUrl       String?
  result          String?  // VALIDATED, ALERT, REJECTED
  aiScore         Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  geometer        Geometer         @relation(fields: [geometerId], references: [id])
  property        Property         @relation("PropertyMissions", fields: [propertyId], references: [id])
  propertyGeom    PropertyGeometry?
  waypoints       GpsWaypoint[]
  report          GeometerReport?
  droneCoverages  DroneCoverage[]

  @@map("geometer_missions")
}

model PropertyGeometry {
  id                  String   @id @default(cuid())
  propertyId          String   @unique
  missionId           String?  @unique
  boundaryPolygon     String?  // GeoJSON POLYGON
  areaSqmMeasured     Float?
  areaSqmDeclared     Float?
  centroidPoint       String?  // GeoJSON POINT
  areaDiscrepancyPct  Float?   // % difference declared vs measured
  lastValidatedAt     DateTime?
  createdAt           DateTime @default(now())

  mission             GeometerMission? @relation(fields: [missionId], references: [id])

  @@map("property_geometries")
}

model GpsWaypoint {
  id          String   @id @default(cuid())
  missionId   String
  pointGeom   String   // GeoJSON POINT
  altitudeM   Float?
  accuracyM   Float?
  capturedAt  DateTime @default(now())

  mission     GeometerMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("gps_waypoints")
}

model ConflictZone {
  id              String   @id @default(cuid())
  propertyIdA     String
  propertyIdB     String
  overlapPolygon  String   // GeoJSON POLYGON
  areaSqmOverlap  Float
  detectedAt      DateTime @default(now())
  status          String   @default("detected") // detected, investigating, resolved, disputed

  @@map("conflict_zones")
}

model GeometerReport {
  id              String   @id @default(cuid())
  missionId       String   @unique
  pdfUrl          String?
  geojsonUrl      String?
  validationStatus String  @default("pending") // pending, validated, rejected
  aiScore         Float?
  blockchainHash  String?  // SHA-256 anchoring on Polygon
  createdAt       DateTime @default(now())

  mission         GeometerMission @relation(fields: [missionId], references: [id])

  @@map("geometer_reports")
}

model DroneCoverage {
  id              String   @id @default(cuid())
  missionId       String
  orthophotoUrl   String?
  mntUrl          String?  // Modèle Numérique de Terrain
  resolutionCm    Float?
  capturedAt      DateTime @default(now())
  bboxPolygon     String?  // GeoJSON POLYGON

  mission         GeometerMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("drone_coverages")
}

model GeoInspection {
  id          String   @id @default(cuid())
  propertyId  String
  geometerId  String
  serviceType String   // GEO_SURF, GEO_INSP, GEO_BORN, GEO_TOPO, GEO_DRON, GEO_CERT
  status      String   @default("requested") // requested, scheduled, in_progress, completed
  reportUrl   String?
  result      String?  // VALIDATED, ALERT, REJECTED
  price       Float
  createdAt   DateTime @default(now())
  completedAt DateTime?

  property    Property @relation(fields: [propertyId], references: [id])

  @@map("geo_inspections")
}

// ============ HOSPITALITY ============

model Hotel {
  id              String   @id @default(cuid())
  name            String
  slug            String?  @unique
  city            String
  country         String
  stars           Int      @default(3)
  rating          Float    @default(0)
  pricePerNight   Float
  currency        String   @default("XOF")
  amenities       String?  // JSON array
  images          String?  // JSON array
  policies        String?  // JSON: checkin/checkout times, cancellation, etc.
  available       Boolean  @default(true)
  connectionLevel Int      @default(1) // 1=OTA, 2=Hors-reseau (PMS), 3=Guesthouse
  ownerId         String?
  otaRefs         String?  // JSON: {booking_com_id, expedia_id, ...}
  lat             Float?
  lng             Float?
  /// PostGIS geometry field — requires PostGIS extension
  geometry        Unsupported("geometry(Point, 4326)")?
  status          String   @default("active") // active, inactive, pending_review
  subscriptionTier String? // starter, pro, enterprise
  subscriptionExpiry DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rooms           HotelRoom[]
  bookings        HotelBooking[]
  reviews_hotel   HotelReview[]
  otaSyncLogs     OtaSyncLog[]
  channelInventory ChannelInventory[] @relation("HotelChannelInventory")

  @@map("hotels")
}

model HotelRoom {
  id          String   @id @default(cuid())
  hotelId     String
  type        String   // single, double, suite, deluxe, family
  name        String?
  capacity    Int      @default(2)
  amenities   String?  // JSON array
  basePriceXof Float
  currency    String   @default("XOF")
  photos      String?  // JSON array of URLs
  totalRooms  Int      @default(1)
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())

  hotel       Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  availability RoomAvailability[]
  channelItems ChannelInventory[]

  @@map("hotel_rooms")
}

model RoomAvailability {
  id            String   @id @default(cuid())
  roomId        String
  date          DateTime
  status        String   @default("AVAILABLE") // AVAILABLE, BOOKED, BLOCKED, MAINTENANCE
  priceOverride Float?
  currency      String   @default("XOF")
  source        String   @default("manual") // manual, ota_booking, channel_manager
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  room          HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_availability")
}

model HotelBooking {
  id              String   @id @default(cuid())
  bookingRef      String?  @unique
  hotelId         String
  roomId          String?
  userId          String
  checkIn         DateTime
  checkOut        DateTime
  guests          Int      @default(1)
  totalPrice      Float
  currency        String   @default("XOF")
  sourceChannel   String   @default("direct") // direct, booking_com, expedia, guesthouse
  status          String   @default("pending") // pending, confirmed, checked_in, completed, cancelled, no_show
  paymentRef      String?
  paymentProvider String?
  specialRequests String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hotel           Hotel        @relation(fields: [hotelId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
  review          HotelReview?

  @@map("hotel_bookings")
}

model HotelReview {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  hotelId     String
  userId      String
  cleanliness Int?     // 1-5
  comfort     Int?     // 1-5
  location    Int?     // 1-5
  value       Int?     // 1-5
  service     Int?     // 1-5
  overall     Int      // 1-5
  comment     String?
  response    String?
  respondedAt DateTime?
  status      String   @default("published") // pending_moderation, published, hidden
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking     HotelBooking @relation(fields: [bookingId], references: [id])
  hotel       Hotel        @relation(fields: [hotelId], references: [id])

  @@map("hotel_reviews")
}

model OtaSyncLog {
  id          String   @id @default(cuid())
  hotelId     String
  ota         String   // booking_com, expedia
  operation   String   // PUSH, PULL
  status      String   @default("pending") // pending, success, failed
  payload     String?  // JSON
  errorMessage String?
  executedAt  DateTime @default(now())

  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("ota_sync_logs")
}

model ChannelInventory {
  id            String   @id @default(cuid())
  roomId        String
  hotelId       String
  ota           String   // booking_com, expedia, direct
  availableCount Int     @default(0)
  rateXof       Float?
  rateEur       Float?
  lastSyncedAt  DateTime @default(now())

  room          HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  hotel         Hotel     @relation("HotelChannelInventory", fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("channel_inventory")
}

// ============ GUESTHOUSES ============

model Guesthouse {
  id              String   @id @default(cuid())
  ownerId         String
  name            String
  slug            String?  @unique
  description     String?
  city            String
  country         String
  quartier        String?
  address         String?
  lat             Float?
  lng             Float?
  /// PostGIS geometry field — requires PostGIS extension
  geometry        Unsupported("geometry(Point, 4326)")?
  images          String?  // JSON array
  amenities       String?  // JSON: common amenities
  rules           String?  // JSON: house rules
  certificationStatus String @default("pending") // pending, certified, rejected, expired
  certifiedAt     DateTime?
  overallRating   Float    @default(0)
  reviewCount     Int      @default(0)
  breakfastAvailable Boolean @default(false)
  breakfastPrice  Float?
  currency        String   @default("XOF")
  hasStaff        Boolean  @default(false)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rooms           GuesthouseRoom[]
  meals           GuesthouseMeal[]
  staff           GuesthouseStaff[]
  pricingRules    GuesthousePricingRule[]
  bookings        GuesthouseBooking[]

  @@map("guesthouses")
}

model GuesthouseRoom {
  id            String   @id @default(cuid())
  guesthouseId  String
  name          String
  capacity      Int      @default(2)
  amenities     String?  // JSON array
  basePrice     Float
  currency      String   @default("XOF")
  photos        String?  // JSON array
  available     Boolean  @default(true)
  instantBooking Boolean @default(true)
  createdAt     DateTime @default(now())

  guesthouse    Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)
  bookings      GuesthouseBooking[]

  @@map("guesthouse_rooms")
}

model GuesthouseMeal {
  id            String   @id @default(cuid())
  guesthouseId  String
  mealType      String   // breakfast, lunch, dinner
  price         Float
  currency      String   @default("XOF")
  includedInPrice Boolean @default(false)
  description   String?
  availableForRoom String? // JSON: room IDs or "all"
  createdAt     DateTime @default(now())

  guesthouse    Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  @@map("guesthouse_meals")
}

model GuesthouseStaff {
  id            String   @id @default(cuid())
  guesthouseId  String
  name          String
  role          String   // receptionist, housekeeping, cook, security
  phone         String?
  schedule      String?  // JSON: work schedule
  accessLevel   Int      @default(1) // 1=basic, 2=dashboard, 3=admin
  createdAt     DateTime @default(now())

  guesthouse    Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  @@map("guesthouse_staff")
}

model GuesthousePricingRule {
  id              String   @id @default(cuid())
  guesthouseId    String
  name            String
  period          String   // low_season, high_season, event, holiday, custom
  multiplier      Float    @default(1.0)
  startDate       DateTime?
  endDate         DateTime?
  event_name      String?
  createdAt       DateTime @default(now())

  guesthouse      Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  @@map("guesthouse_pricing_rules")
}

model GuesthouseBooking {
  id              String   @id @default(cuid())
  bookingRef      String?  @unique
  guesthouseId    String
  roomId          String
  userId          String
  checkIn         DateTime
  checkOut        DateTime
  guests          Int      @default(1)
  totalPrice      Float
  currency        String   @default("XOF")
  breakfastIncluded Boolean @default(false)
  status          String   @default("pending") // pending, confirmed, checked_in, completed, cancelled
  paymentRef      String?
  paymentProvider String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  guesthouse      Guesthouse     @relation(fields: [guesthouseId], references: [id])
  room            GuesthouseRoom @relation(fields: [roomId], references: [id])
  user            User           @relation(fields: [userId], references: [id])

  @@map("guesthouse_bookings")
}

// ============ PROFESSIONAL PROFILES (LinkedIn-like) ============

model ProfessionalProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  headline        String?  // professional title
  coverPhoto      String?
  bio             String?  // 500 chars max
  specialities    String?  // JSON array of skills
  languages       String?  // JSON array: [{lang, level}]
  availability    String?  // available, busy, unavailable
  credibilityScore Int    @default(0) // 0-100
  completenessPct Int     @default(0) // profile completeness percentage
  isPublic        Boolean  @default(true)
  slug            String?  @unique // afribayit.com/pro/kofi-mensah
  experience      String?  // JSON array of experience objects
  education       String?  // JSON array of education objects
  certifications  String?  // JSON array of badge/cert objects
  portfolio       String?  // JSON array of project objects
  country         String?  // BJ, CI, BF, TG — pays d'activité
  zone            String?  // zone d'intervention
  agencyName      String?  // for agents
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endorsements    SkillEndorsement[]

  @@map("professional_profiles")
}

model SkillEndorsement {
  id            String   @id @default(cuid())
  profileId     String
  endorserId    String
  skill         String
  createdAt     DateTime @default(now())

  profile       ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  endorser      User                @relation(fields: [endorserId], references: [id], onDelete: Cascade)

  @@unique([profileId, endorserId, skill])
  @@map("skill_endorsements")
}

model UserConnection {
  id          String   @id @default(cuid())
  requesterId String
  targetId    String
  status      String   @default("pending") // pending, accepted, blocked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   User     @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  target      User     @relation("Target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@map("user_connections")
}

model ProfileView {
  id          String   @id @default(cuid())
  viewedId    String
  viewerId    String
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  viewed      User     @relation("ProfileViewed", fields: [viewedId], references: [id], onDelete: Cascade)
  viewer      User     @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@map("profile_views")
}

// ============ SUBSCRIPTIONS ============

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  planType    String   // agent_seed, agent_grow, agent_lead, agent_network, pms_starter, pms_pro, pms_enterprise, artisan_pro, geometer_pro, notary_pro, academy_basic, academy_pro
  priceXof    Float
  currency    String   @default("XOF")
  country     String?  // BJ, CI, BF, TG — marché
  status      String   @default("active") // active, cancelled, expired, past_due
  startDate   DateTime
  endDate     DateTime?
  autoRenew   Boolean  @default(true)
  paymentRef  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============ CHAT / REBECCA IA ============

model Conversation {
  id          String   @id @default(cuid())
  type        String   @default("rebecca") // rebecca, user_to_user, support
  status      String   @default("active") // active, closed, archived
  metadata    String?  // JSON: additional context
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String   @default("participant") // participant, admin
  lastReadAt     DateTime?
  joinedAt       DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  messageType    String   @default("text") // text, property_card, image, file, system, quick_reply
  metadata       String?  // JSON: property data for property_card, etc.
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@map("chat_messages")
}

// ============ COUNTRY ACCREDITATIONS ============

model CountryAccreditation {
  id          String   @id @default(cuid())
  userId      String
  country     String   // BJ, CI, BF, TG, ALL (ALL = SUPER_ADMIN access to all countries)
  role        String   @default("COUNTRY_ADMIN") // SUPER_ADMIN, COUNTRY_ADMIN
  grantedBy   String?  // userId of admin who granted
  grantedAt   DateTime @default(now())
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, country])
  @@map("country_accreditations")
}

// ============ SAVED SEARCHES & ALERTS ============

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String
  name          String
  filters       String   // JSON: SearchFilters object
  lastCheckedAt DateTime?
  newMatches    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("saved_searches")
}

model PriceAlert {
  id              String   @id @default(cuid())
  userId          String
  filters         String   // JSON: SearchFilters object
  notifyVia       String   @default("email") // email, push, sms, whatsapp
  frequency       String   @default("daily") // instant, daily, weekly
  active          Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("price_alerts")
}

// ============ QUIZ & ASSESSMENTS ============

model Quiz {
  id            String   @id @default(cuid())
  courseId      String
  title         String
  description   String?
  timeLimit     Int      @default(30)
  passingScore  Int      @default(70)
  maxAttempts   Int      @default(3)
  questions     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course        Course      @relation(fields: [courseId], references: [id])
  attempts      QuizAttempt[]

  @@map("quizzes")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  answers     Json
  score       Int
  maxScore    Int
  percent     Int
  passed      Boolean
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  quiz        Quiz     @relation(fields: [quizId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@map("quiz_attempts")
}

// ============ CERTIFICATES ============

model Certificate {
  id              String   @id @default(cuid())
  certificateId   String   @unique
  userId          String
  courseId        String
  enrollmentId    String?
  type            String   @default("course_completion") // course_completion, workshop, masterclass
  recipientName   String
  courseName      String
  instructorName  String
  pdfUrl          String?
  pdfBase64       String?
  issuedAt        DateTime @default(now())
  verified        Boolean  @default(true)

  user            User     @relation(fields: [userId], references: [id])
  course          Course   @relation(fields: [courseId], references: [id])

  @@map("certificates")
}

// ============ AFRIPOINTS ============

model AfriPointTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // earn, spend
  action      String   // post_created, quiz_passed, course_completed, boost_listing_7d, etc.
  points      Int
  balanceAfter Int
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("afripoint_transactions")
}

// ============ AMBASSADOR PROGRAM ============

model Ambassador {
  id              String   @id @default(cuid())
  userId          String   @unique
  tier            String   @default("bronze") // bronze, silver, gold
  referralCode    String   @unique
  referralLink    String?
  commissionRate  Float    @default(0.05)
  totalReferrals  Int      @default(0)
  totalEarnings   Float    @default(0)
  status          String   @default("active") // active, pending, suspended
  appliedAt       DateTime @default(now())
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  commissions     AmbassadorCommission[]

  @@map("ambassadors")
}

model AmbassadorCommission {
  id              String   @id @default(cuid())
  ambassadorId    String
  referredUserId  String
  transactionId   String?
  amount          Float
  commissionRate  Float
  status          String   @default("pending") // pending, paid, cancelled
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  ambassador      Ambassador @relation(fields: [ambassadorId], references: [id])

  @@map("ambassador_commissions")
}

// ============ FOLLOWERS ============

model Follower {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  
  follower    User     @relation("Following", fields: [followerId], references: [id])
  following   User     @relation("Followers", fields: [followingId], references: [id])
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("followers")
}

// ============ SHORT-TERM RENTALS (Location Courte Durée — Airbnb Model) ============

model ShortTermRental {
  id              String   @id @default(cuid())
  hostId          String
  title           String
  slug            String?  @unique
  description     String?
  propertyType    String   // appartement, villa, studio, chambre, maison, loft, bungalow
  city            String
  country         String
  quartier        String?
  address         String?
  lat             Float?
  lng             Float?
  images          String?  // JSON array of URLs
  pricePerNight   Float
  weeklyPrice     Float?
  monthlyPrice    Float?
  currency        String   @default("XOF")
  maxGuests       Int      @default(2)
  bedrooms        Int      @default(1)
  bathrooms       Int      @default(1)
  beds           Int      @default(1)
  amenities       String?  // JSON array: wifi, ac, pool, kitchen, parking, etc.
  houseRules      String?  // JSON: check-in time, check-out time, no smoking, no pets, etc.
  instantBooking  Boolean  @default(false)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  views           Int      @default(0)
  otaRefs         String?  // JSON: {airbnb_id, booking_com_id, ...}
  otaSyncStatus   String?  // JSON: {airbnb: "synced", booking_com: "pending", ...}
  hostVerified    Boolean  @default(false)
  hostIdentityVerified Boolean @default(false)
  status          String   @default("active") // active, inactive, pending_review, suspended
  minStayNights   Int      @default(1)
  maxStayNights   Int?
  cancellationPolicy String @default("flexible") // flexible, moderate, strict
  cleaningFee     Float    @default(0)
  securityDeposit Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        ShortTermRentalBooking[]
  availability    ShortTermRentalAvailability[]
  pricingRules    ShortTermRentalPricingRule[]
  reviews_str     ShortTermRentalReview[]

  @@map("short_term_rentals")
}

model ShortTermRentalAvailability {
  id            String   @id @default(cuid())
  rentalId      String
  date          DateTime
  status        String   @default("AVAILABLE") // AVAILABLE, BOOKED, BLOCKED, MAINTENANCE
  priceOverride Float?
  currency      String   @default("XOF")
  source        String   @default("manual") // manual, ota_booking, airbnb, booking_com
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rental        ShortTermRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@unique([rentalId, date])
  @@map("short_term_rental_availability")
}

model ShortTermRentalPricingRule {
  id              String   @id @default(cuid())
  rentalId        String
  name            String
  period          String   // low_season, high_season, event, holiday, weekend, custom
  multiplier      Float    @default(1.0)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())

  rental          ShortTermRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("short_term_rental_pricing_rules")
}

model ShortTermRentalBooking {
  id              String   @id @default(cuid())
  bookingRef      String?  @unique
  rentalId        String
  userId          String
  checkIn         DateTime
  checkOut        DateTime
  guests          Int      @default(1)
  nights          Int
  pricePerNight   Float
  cleaningFee     Float    @default(0)
  securityDeposit Float    @default(0)
  totalPrice      Float
  serviceFee      Float    @default(0)
  currency        String   @default("XOF")
  bookingType     String   @default("instant") // instant, request
  sourceChannel   String   @default("direct") // direct, airbnb, booking_com
  status          String   @default("pending") // pending, confirmed, checked_in, completed, cancelled, declined
  paymentRef      String?
  paymentProvider String?  // fedapay, stripe
  specialRequests String?
  hostResponse    String?
  cancelledAt     DateTime?
  cancellationReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rental          ShortTermRental @relation(fields: [rentalId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  review          ShortTermRentalReview?

  @@map("short_term_rental_bookings")
}

model ShortTermRentalReview {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  rentalId    String
  userId      String
  cleanliness Int?     // 1-5
  accuracy    Int?     // 1-5
  communication Int?   // 1-5
  location    Int?     // 1-5
  checkIn     Int?     // 1-5
  value       Int?     // 1-5
  overall     Int      // 1-5
  comment     String?
  hostResponse String?
  respondedAt DateTime?
  status      String   @default("published") // pending_moderation, published, hidden
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking     ShortTermRentalBooking @relation(fields: [bookingId], references: [id])
  rental      ShortTermRental        @relation(fields: [rentalId], references: [id])

  @@map("short_term_rental_reviews")
}

// ============ SCHEDULED PAYOUTS (J+1 Engine) ============

model ScheduledPayout {
  id              String   @id @default(cuid())
  transactionId   String
  recipientId     String
  amount          Float
  currency        String   @default("XOF")
  method          String   // mobile_money, bank_transfer, fedapay
  destination     String   // phone number or bank account ref
  country         String   @default("BJ") // BJ, CI, BF, TG
  status          String   @default("scheduled") // scheduled, processing, completed, failed
  scheduledAt     DateTime // when the payout should be executed
  processedAt     DateTime?
  providerRef     String?
  confirmationRef String?
  failureReason   String?
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  metadata        String?  // JSON: additional context
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([recipientId])
  @@map("scheduled_payouts")
}
